{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "general": {
    "defaultApprovalMode": "default"
  },
  "security": {
    "disableYoloMode": true,
    "enablePermanentToolApproval": false,
    "environmentVariableRedaction": {
      "enabled": true,
      "redactedVariablePatterns": [
        ".*TOKEN.*",
        ".*SECRET.*",
        ".*PASSWORD.*",
        ".*KEY.*",
        ".*AUTH.*",
        ".*CREDENTIAL.*",
        ".*PRIVATE.*",
        ".*CERT.*"
      ]
    },
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "tools": {
    "sandbox": true,
    "allowed": [
      "Read",
      "Glob",
      "Grep",
      "BashCommand(git status)",
      "BashCommand(git log *)",
      "BashCommand(git diff *)",
      "BashCommand(git show *)",
      "BashCommand(git branch)",
      "BashCommand(git remote -v)",
      "BashCommand(ls *)",
      "BashCommand(pwd)",
      "BashCommand(echo *)",
      "BashCommand(cat *)",
      "BashCommand(grep *)",
      "BashCommand(find *)",
      "BashCommand(mkdir *)",
      "BashCommand(touch *)"
    ],
    "exclude": [
      "BashCommand(rm -rf *)",
      "BashCommand(rm -fr *)",
      "BashCommand(sudo rm *)",
      "BashCommand(git reset --hard *)",
      "BashCommand(git push --force *)",
      "BashCommand(git push -f *)",
      "BashCommand(git clean -fd *)",
      "BashCommand(curl *)",
      "BashCommand(wget *)",
      "BashCommand(nc *)",
      "BashCommand(netcat *)"
    ],
    "shell": {
      "enableInteractiveShell": false,
      "inactivityTimeout": 120
    },
    "truncateToolOutputThreshold": 30000
  },
  "mcpServers": {
    "github-mcp-server": {
      "httpUrl": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_API_TOKEN}"
      },
      "trust": false,
      "timeout": 30000
    },
    "backlog": {
      "command": "docker",
      "args": [
        "run",
        "--pull",
        "always",
        "-i",
        "--rm",
        "-e",
        "BACKLOG_DOMAIN",
        "-e",
        "BACKLOG_API_KEY",
        "ghcr.io/nulab/backlog-mcp-server:latest"
      ],
      "timeout": 30000
    },
    "drawio": {
      "command": "npx",
      "args": ["-y", "@drawio/mcp@latest"]
    },
    "docker": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    }
  },
  "context": {
    "fileName": "GEMINI.md",
    "fileFiltering": {
      "respectGitIgnore": true
    }
  },
  "model": {
    "maxSessionTurns": 50,
    "summarizeToolOutput": {
      "run_shell_command": {
        "tokenBudget": 10000
      }
    }
  },
  "admin": {
    "secureModeEnabled": true,
    "extensions": {
      "enabled": false
    },
    "mcp": {
      "enabled": true
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "ui": {
    "hideContextSummary": false,
    "hideBanner": false
  }
}
